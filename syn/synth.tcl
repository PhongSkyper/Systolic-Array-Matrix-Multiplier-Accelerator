################################################################################ FILE   : synth.tcl# TOOL   : Cadence Genus 21+# PDK    : GPDK045 (45nm) - 8 corners# DESIGN : system_top## CORNER STRATEGY:#   Synthesis target : slow_vdd1v0_lvt (worst-worst setup)#   Hold check       : fast_vdd1v2_lvt (best-best hold)#   Full MMMC STA    : all 8 corners via sta.tcl after synthesis## USAGE:#   cd <project>/syn#   genus -f synth.tcl |& tee synth.log###############################################################################set DESIGN   "system_top"set RTL_DIR  "../rtl"set LIB_DIR  "../lib/gpdk045/gpdk045_lib"set RPT_DIR  "./reports"set OUT_DIR  "./outputs"file mkdir $RPT_DIRfile mkdir $OUT_DIR################################################################################ 1. Load libraries#    Synthesize targeting worst-worst corner (slow_vdd1v0) for setup closure#    Include fast corner so Genus can check hold during optimization###############################################################################set_db library "    ${LIB_DIR}/slow_vdd1v0_basicCells_lvt.lib    ${LIB_DIR}/slow_vdd1v0_basicCells_hvt.lib    ${LIB_DIR}/slow_vdd1v2_basicCells_lvt.lib    ${LIB_DIR}/slow_vdd1v2_basicCells_hvt.lib    ${LIB_DIR}/fast_vdd1v2_basicCells_lvt.lib    ${LIB_DIR}/fast_vdd1v2_basicCells_hvt.lib    ${LIB_DIR}/fast_vdd1v0_basicCells_lvt.lib    ${LIB_DIR}/fast_vdd1v0_basicCells_hvt.lib"################################################################################ 2. Read RTL###############################################################################read_hdl -sv ${RTL_DIR}/pkg/uart_pkg.svread_hdl -sv ${RTL_DIR}/primitives/gates.svread_hdl -sv ${RTL_DIR}/primitives/adders.svread_hdl -sv ${RTL_DIR}/primitives/fifo_sync_structured.svread_hdl -sv ${RTL_DIR}/primitives/ksa_32bit.svread_hdl -sv ${RTL_DIR}/multiplier/booth_wallace_8x8.svread_hdl -sv ${RTL_DIR}/systolic/delay_line.svread_hdl -sv ${RTL_DIR}/systolic/pe.svread_hdl -sv ${RTL_DIR}/systolic/global_controller.svread_hdl -sv ${RTL_DIR}/systolic/systolic_array_top.svread_hdl -sv ${RTL_DIR}/uart/uart_rx.svread_hdl -sv ${RTL_DIR}/uart/uart_tx.svread_hdl -sv ${RTL_DIR}/uart/uart_top.svread_hdl -sv ${RTL_DIR}/top/system_top.sv################################################################################ 3. Elaborate###############################################################################elaborate $DESIGNcheck_design -unresolved################################################################################ 4. Constraints#    Clock: 50 MHz nominal. Tight to worst-worst corner.#    UART signals are asynchronous -> false path###############################################################################set CLOCK_PERIOD 2.0create_clock -name clk -period $CLOCK_PERIOD [get_ports clk]# Clock uncertainty: jitter + skew marginset_clock_uncertainty 0.5 [get_clocks clk]# Async ports -> false path (UART signals have internal synchronizers)set_false_path -from [get_ports rst_n]set_false_path -from [get_ports rx]set_false_path -from [get_ports is_signed]set_false_path -to   [get_ports tx]################################################################################ 5. Synthesis effort###############################################################################set_db syn_generic_effort  mediumset_db syn_map_effort      mediumset_db syn_opt_effort      medium################################################################################ 6. Run synthesis###############################################################################syn_genericsyn_mapsyn_opt################################################################################ 7. Reports###############################################################################report_timing > ${RPT_DIR}/setup_timing.rptreport_area   > ${RPT_DIR}/area.rptreport_power  > ${RPT_DIR}/power.rptreport_gates  > ${RPT_DIR}/gates.rptreport_qor    > ${RPT_DIR}/qor.rpt# Screen summaryputs "\n============================================"puts "  SYNTHESIS COMPLETE"puts "============================================"puts "\n-- Worst Setup Path --"report_timing -max_paths 1report_area -summaryputs "============================================\n"################################################################################ 8. Write outputs###############################################################################write_hdl  > ${OUT_DIR}/${DESIGN}_netlist.vwrite_sdc  > ${OUT_DIR}/${DESIGN}_syn.sdcwrite_db     ${OUT_DIR}/${DESIGN}_syn.dbputs "Netlist : ${OUT_DIR}/${DESIGN}_netlist.v"puts "SDC     : ${OUT_DIR}/${DESIGN}_syn.sdc"puts "Reports : ${RPT_DIR}/"